APP_NAME=LegalOpsAI-Pipeline
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
LOG_FORMAT=console
SECRET_KEY=change-me-to-random-64-bytes-hex-string-in-production
PASETO_KEY=change-me-to-random-32-bytes-hex-string-for-paseto

API_HOST=0.0.0.0
API_PORT=8079
API_WORKERS=1
CORS_ORIGINS=["http://localhost:3001","http://localhost:8079"]

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=legalops
POSTGRES_PASSWORD=legalops_secret
POSTGRES_DB=legalops_db
DATABASE_URL=postgresql+asyncpg://legalops:legalops_secret@localhost:5433/legalops_db

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380/0

CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

OLLAMA_BASE_URL=http://localhost:11435
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120

LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local
LANGFUSE_HOST=http://localhost:3002

OTEL_SERVICE_NAME=legalops-ai-pipeline
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_ENABLED=true

PROMETHEUS_PORT=9091

GRAFANA_PORT=3001
GF_SECURITY_ADMIN_PASSWORD=legalops

TEMPO_PORT=3201

LOKI_PORT=3101

FLOWER_PORT=5556

RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=8
RAG_RERANK_TOP_N=5
RAG_SIMILARITY_THRESHOLD=0.35
RAG_HYBRID_SEARCH=true
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIMENSION=768

CLASSIFIER_CONFIDENCE_THRESHOLD=0.30
VERIFIER_ACCURACY_THRESHOLD=0.60
MAX_GENERATION_RETRIES=2

HITL_SLA_URGENT_HOURS=2
HITL_SLA_HIGH_HOURS=4
HITL_SLA_NORMAL_HOURS=8

RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_SEARCH=30/minute
